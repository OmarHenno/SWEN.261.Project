<!DOCTYPE html>
<html>
<head>
    <title>Wandria Flights</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Available Flights</h1>

<table>
    <tr>
        <th>Flight #</th>
        <th>Destination</th>
        <th>Category</th>
        <th>Date</th>
        <th>Seats</th>
        <th>Price</th>
        <th>Status</th>
    </tr>

    {{#flights}}
        <tr>
            <td>{{flightNumber}}</td>
            <td>{{destination}}</td>
            <td>{{category}}</td>
            <td>{{formattedDepartureTime}}</td>
            <td>{{seatsAvailable}}</td>
            <td>{{price}}</td>
            <td>{{availabilityStatus}}</td>
        </tr>
   {{/flights}}

</table>

</body>
</html>