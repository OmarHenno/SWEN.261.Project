<!DOCTYPE html>
<html>
<head>
    <title>Wandria Flights</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Available Flights</h1>

<a href="/collection">
    <button>View My Collection</button>
</a>

<h2>Search Flights by Destination</h2>

<select id="categorySelect">
    <option value="">Select Category...</option>
    <option value="Domestic">Domestic</option>
    <option value="International">International</option>
</select>
<button onclick="searchByCategory()">Search Category</button>

<input type="text" id="nameInput" placeholder="e.g. Paris, Dubai, London">
<button onclick="searchByName()">Search</button>
<button onclick="resetResults()">Show All</button>

<div id="search-results"></div>

<table>
    <tr>
        <th>Flight #</th>
        <th>Destination</th>
        <th>Category</th>
        <th>Date</th>
        <th>Seats</th>
        <th>Price</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    {{#flights}}
        <tr>
            <td>{{flightNumber}}</td>
            <td>{{destination}}</td>
            <td>{{category}}</td>
            <td>{{formattedDepartureTime}}</td>
            <td>{{seatsAvailable}}</td>
            <td>{{price}}</td>
            <td>{{availabilityStatus}}</td>
            <td>
                <button onclick="addToCollection('{{flightNumber}}')">Add to My Collection</button>
            </td>
        </tr>
   {{/flights}}

</table>

<script>
    function searchByName() {
        const keyword = document.getElementById('nameInput').value.trim();
        const container = document.getElementById('search-results');

        if (!keyword) {
            container.innerHTML = '<p>Please enter a destination.</p>';
            return;
        }

        fetch(`/api/flights/search/name?keyword=${encodeURIComponent(keyword)}`)
                .then(response => response.json())
                .then(flights => {
                    if (!flights || flights.length === 0) {
                        container.innerHTML = '<p>No results found.</p>';
                        return;
                    }

                    container.innerHTML = `
                    <h3>Search Results</h3>
                    <table>
                        <tr>
                            <th>Flight #</th>
                            <th>Destination</th>
                            <th>Category</th>
                            <th>Date</th>
                            <th>Seats</th>
                            <th>Price</th>
                            <th>Status</th>
                        </tr>
                        ${flights.map(f => `
                            <tr>
                                <td>${f.flightNumber}</td>
                                <td>${f.destination}</td>
                                <td>${f.category}</td>
                                <td>${f.formattedDepartureTime}</td>
                                <td>${f.seatsAvailable}</td>
                                <td>${f.price}</td>
                                <td>${f.availabilityStatus}</td>
                            </tr>
                        `).join('')}
                    </table>
                `;
                })
                .catch(error => {
                    console.error('Search failed:', error);
                    container.innerHTML = '<p>Search failed. Please try again.</p>';
                });
    }
        function searchByCategory() {
            const category = document.getElementById('categorySelect').value;
            const container = document.getElementById('search-results');

            if (!category) {
                container.innerHTML = '<p>Please select a category from the dropdown.</p>';
                return;
            }

            fetch(`/api/flights/search/category?category=${encodeURIComponent(category)}`)
                    .then(response => response.json())
                    .then(flights => {
                        if (!flights || flights.length === 0) {
                            container.innerHTML = '<p>No flights found for this category.</p>';
                            return;
                        }

                        container.innerHTML = `
                    <h3>Category Results: ${category}</h3>
                    <table>
                        <tr>
                            <th>Flight #</th>
                            <th>Destination</th>
                            <th>Category</th>
                            <th>Date</th>
                            <th>Seats</th>
                            <th>Price</th>
                            <th>Status</th>
                        </tr>
                        ${flights.map(f => `
                            <tr>
                                <td>${f.flightNumber}</td>
                                <td>${f.destination}</td>
                                <td>${f.category}</td>
                                <td>${f.formattedDepartureTime}</td>
                                <td>${f.seatsAvailable}</td>
                                <td>${f.price}</td>
                                <td>${f.availabilityStatus}</td>
                            </tr>
                        `).join('')}
                    </table>
                `;
                    })
                    .catch(error => {
                        console.error('Search failed:', error);
                        container.innerHTML = '<p>Category search failed. Please try again.</p>';
                    });

    }

    function resetResults() {
        document.getElementById('search-results').innerHTML = '';
        document.getElementById('nameInput').value = '';
    }
    function addToCollection(flightNumber) {
        fetch(`/api/flights/collection?flightNumber=${encodeURIComponent(flightNumber)}`, {
            method: 'POST'
        })
                .then(response => response.text())
                .then(message => {
                    alert(message);
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Failed to add flight.');
                });
    }
</script>

</body>
</html>